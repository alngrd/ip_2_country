PORT=8080
DATABASE_URL=
REDIS_URL=

# Memory fallback RPS when Redis is unavailable
RATE_LIMIT_RPS=10

# Tier 1 — Velocity detection: blocks IPs whose requests consistently arrive faster than 50ms apart
RATE_LIMIT_BURST_SUSPICION_THRESHOLD=10

# Tier 2 — Per-connection cap (IP + source port)
RATE_LIMIT_PER_PORT_LIMIT=300
RATE_LIMIT_PER_PORT_WINDOW=1m

# Tier 3 — Global per-IP cap (evaluated first; every request counts regardless of other tiers)
RATE_LIMIT_IP_LIMIT=2000
RATE_LIMIT_IP_WINDOW=1m

# 404 scrape detection: blocks IPs that accumulate too many not-found responses
RATE_LIMIT_NOT_FOUND_LIMIT=20
RATE_LIMIT_NOT_FOUND_WINDOW=10m
